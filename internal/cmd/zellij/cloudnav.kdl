// cloudnav Zellij layout — cloudnav fills its tab; a sibling
// shell tab handles ad-hoc cloud-CLI work without cramping the
// navigator.
//
// Shipped under
//     <UserConfigDir>/cloudnav/zellij/cloudnav.kdl
// and selected at exec time via `zellij --config-dir`, so the
// user's own ~/.config/zellij stays untouched.
//
// Design intent (per the user feedback that prompted the rewrite):
//   - Zellij looks like Zellij. Default theme, native tab bar,
//     native status bar, native keybindings. We do NOT theme it
//     to mimic the cloudnav TUI palette.
//   - cloudnav fills its tab. The TUI was designed for full-
//     width — the table columns, breadcrumbs, and keybar all
//     assume the entire terminal width is available, and a
//     vertical split made everything cramped (the previous
//     60/40 layout was the regression that prompted this fix).
//   - Shell tab as a sibling, not a side pane. Users who want
//     a shell alongside the navigator switch tabs via the
//     native Ctrl-t (then '2' or arrow keys), or split the
//     navigator pane themselves with Ctrl-p '|' for a vertical
//     split / Ctrl-p '-' for horizontal. Either is one keystroke
//     of native Zellij muscle memory.

layout {
    default_tab_template {
        // Zellij's standard tab bar at the top — shows tab
        // labels and the active tab; users tab-switch with
        // Ctrl-t.
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        // Zellij's standard status bar at the bottom — shows
        // the active mode (Normal / Pane / Tab / …) and the
        // keybindings for that mode. Critical to keep so users
        // know how to navigate the workspace.
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    // Tab 1 — cloudnav fills the entire tab.
    tab name="cloudnav" focus=true {
        pane name="navigator" {
            command "cloudnav"
        }
    }

    // Tab 2 — clean shell for `gcloud` / `aws` / `az` /
    // `kubectl` / `terraform` / anything else, switchable via
    // Ctrl-t '2' (or arrow keys in tab mode).
    tab name="shell" {
        pane
    }
}
